<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home"> <!-- Destino inicial: "Rutas" -->

    <!-- Define los fragments correspondientes a cada opción del menú -->

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.conectatec.homeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/nav_schedules"
        android:name="com.example.conectatec.HorariosFragment"
        android:label="Horarios" />

    <fragment
        android:id="@+id/nav_routes"
        android:name="com.example.conectatec.RutasFragment"

        android:label="Rutas" />

    <fragment
        android:id="@+id/nav_history"
        android:name="com.example.conectatec.HistorialFragment"
        android:label="Historial" />

    <fragment
        android:id="@+id/nav_wallet"
        android:name="com.example.conectatec.walletFragment"
        android:label="Wallet" />

    <fragment
        android:id="@+id/nav_notifications"
        android:name="com.example.conectatec.NotificacionesFragment"
        android:label="QR" />

</navigation>