<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BotonApp" parent="Widget.Material3.Button">
        <item name="cornerRadius">20dp</item>
        <item name="backgroundTint">@color/orange</item> <!-- Nota: Para MaterialButton, es más común usar "backgroundTint" sin "android:" -->
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <!-- res/values/styles.xml -->
    <style name="TextAppearance.App.CeldaEncabezado" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- res/values/styles.xml -->
    <style name="Widget.App.CeldaEncabezado" parent=""> <!-- Puedes dejar el parent vacío o buscar uno apropiado para TextView si existe -->
        <item name="android:layout_width">0dp</item> <!-- Para TableLayout con stretchColumns, usar 0dp y layout_weight=1 es común -->
        <item name="android:layout_height">wrap_content</item> <!-- O 44.5dp si es una altura fija obligatoria -->
        <item name="android:layout_weight">1</item> <!-- Si quieres que las columnas se repartan el espacio -->
        <item name="android:background">@color/orange</item>
        <item name="android:gravity">center_horizontal</item> <!-- Para centrar el texto dentro de la celda -->
        <item name="android:textAppearance">@style/TextAppearance.App.CeldaEncabezado</item>
    </style>




</resources>